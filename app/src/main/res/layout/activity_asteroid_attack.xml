<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/gameContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/asteroid_bg"
    android:clipChildren="false">

    <!-- ── Top Left: Coin Display ─────────────────────────────── -->
    <LinearLayout
        android:id="@+id/coinDisplay"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/coin_display_bg"
        android:paddingStart="10dp"
        android:paddingEnd="14dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/coin_bg"/>

        <TextView
            android:id="@+id/tvCoins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"/>
    </LinearLayout>

    <!-- ── Top Right: Energy & Stats ───────────────────────────── -->
    <LinearLayout
        android:id="@+id/statsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvEnergyLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current Energy Level: 100"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvDamage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Damage Taken: 0/5"
            android:textColor="#FF5555"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvPowerBoostCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#00FF00"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- ── Enemies & Player ────────────────────────────────────── -->
    <ImageView
        android:id="@+id/ivUfo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ufo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="100dp"/>

    <ImageView
        android:id="@+id/ivRocketship"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/rocketship"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="140dp"/>

    <!-- ── Control Row ─────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/controlRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnLeft"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="←"
            android:textSize="20sp"
            android:backgroundTint="#88FFFFFF"
            android:textColor="#000000"/>

        <Button
            android:id="@+id/btnAttack"
            android:layout_width="120dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="16dp"
            android:text="ATTACK"
            android:backgroundTint="#CC2D82"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnRight"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="→"
            android:textSize="20sp"
            android:backgroundTint="#88FFFFFF"
            android:textColor="#000000"/>
    </LinearLayout>

    <!-- ── Action Buttons ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/controlRow"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnPowerBoost"
            android:layout_width="110dp"
            android:layout_height="50dp"
            android:text="Power Boost\n(5🪙)"
            android:textSize="10sp"
            android:backgroundTint="#FFD700"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnEvade"
            android:layout_width="110dp"
            android:layout_height="50dp"
            android:text="Evade"
            android:textSize="10sp"
            android:backgroundTint="#2196F3"
            android:visibility="gone"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
