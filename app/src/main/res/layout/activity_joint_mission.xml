<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_space_home"
    android:padding="16dp">

    <!-- Header Area -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="JOINT MISSION"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <LinearLayout
        android:id="@+id/coinDisplay"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/coin_display_bg"
        android:paddingStart="10dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/coin_bg"/>

        <TextView
            android:id="@+id/tvCoins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"/>
    </LinearLayout>

    <!-- Visual Area -->
    <LinearLayout
        android:id="@+id/visualArea"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <ImageView
            android:id="@+id/ivCrewA"
            android:layout_width="70dp"
            android:layout_height="120dp"
            android:scaleType="fitCenter"
            android:src="@drawable/pilot"/>

        <ImageView
            android:id="@+id/ivCrewB"
            android:layout_width="70dp"
            android:layout_height="120dp"
            android:scaleType="fitCenter"
            android:src="@drawable/soldier"
            android:layout_marginStart="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VS"
            android:textColor="#FF0000"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginHorizontal="12dp"/>

        <ImageView
            android:id="@+id/ivThreat"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ufo"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:background="#44000000"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/visualArea"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#CC000000"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintBottom_toTopOf="@id/buttonPanel">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="13sp" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/buttonPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnAttack"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="ATTACK"
            android:backgroundTint="#8B0000"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnDefend"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="DEFEND"
            android:backgroundTint="#00008B"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp"/>

        <Button
            android:id="@+id/btnSpecial"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="SPECIAL"
            android:backgroundTint="#006400"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
