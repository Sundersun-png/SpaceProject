<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- BACKGROUND: neon arena / mission control room -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_missioncontrol"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000015" />

    <!-- ══ TOP BAR ══ -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#BB000020"
        android:layout_alignParentTop="true">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@android:color/transparent"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="MISSION CONTROL"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/tvCoins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="12dp"
            android:text="🪙 300"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- ══ SCROLLABLE CONTENT ══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▸ SELECT CREW MEMBERS"
                android:textColor="#9B72CF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp" />

            <!-- CREW A and CREW B side by side -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- ── CREW A CARD ── -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#DD0A0A1E"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CREW A  (Your Team)"
                        android:textColor="#CC2D82"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerCrewA"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#331A3A5C"
                        android:popupBackground="#1A0A2E" />

                    <!-- Portrait shown after selection -->
                    <ImageView
                        android:id="@+id/imgCrewA"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:scaleType="centerCrop"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"
                        android:contentDescription="Crew A portrait" />

                    <!-- Stats line -->
                    <TextView
                        android:id="@+id/tvCrewAStats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#AAAACC"
                        android:textSize="10sp"
                        android:layout_marginTop="6dp" />

                </LinearLayout>

                <!-- ── CREW B CARD ── -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#DD0A0A1E"
                    android:padding="12dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CREW B  (Opponent)"
                        android:textColor="#2D82CC"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerCrewB"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="#331A3A5C"
                        android:popupBackground="#1A0A2E" />

                    <!-- Opponent portrait shown after selection -->
                    <ImageView
                        android:id="@+id/imgCrewB"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:scaleType="centerCrop"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"
                        android:contentDescription="Crew B portrait" />

                </LinearLayout>

            </LinearLayout>

            <!-- MISSION TYPE SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▸ SELECT MISSION TYPE"
                android:textColor="#9B72CF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#DD0A0A1E"
                android:padding="14dp"
                android:layout_marginBottom="20dp">

                <Spinner
                    android:id="@+id/spinnerMission"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="#331A3A5C"
                    android:popupBackground="#1A0A2E" />

            </LinearLayout>

            <!-- LAUNCH BUTTON -->
            <Button
                android:id="@+id/btnLaunchMission"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="🚀  LAUNCH MISSION"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.1"
                android:backgroundTint="#CC2D82"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>