<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_mission">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT CREW MEMBERS"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CREW A"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvCrewA"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="SELECT.."
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:background="@drawable/bg_crew_card"
                        android:padding="8dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CREW B"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvCrewB"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="SELECT.."
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:background="@drawable/bg_crew_card"
                        android:padding="8dp"/>

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MISSION TYPE"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvMissionType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#AAFFAA"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnAsteroid"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="ASTEROID FIELD"
                android:textColor="#222222"
                android:textStyle="bold"
                android:backgroundTint="#FFFFFFFF"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnReactor"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="REACTOR MELTDOWN"
                android:textColor="#222222"
                android:textStyle="bold"
                android:backgroundTint="#FFFFFFFF"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnVirus"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="VIRUS OUTBREAK"
                android:textColor="#222222"
                android:textStyle="bold"
                android:backgroundTint="#FFFFFFFF"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnAlien"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="ALIEN ATTACK"
                android:textColor="#222222"
                android:textStyle="bold"
                android:backgroundTint="#FFFFFFFF"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnPotion"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="POTION MAKING"
                android:textColor="#222222"
                android:textStyle="bold"
                android:backgroundTint="#FFFFFFFF"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnLaunchMission"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="LAUNCH MISSION"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="#CCEC407A"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>