<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_soldier_mission">

    <!-- Cloud/Mist Overlay -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#22FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Back button -->
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:text="← Back"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="@drawable/coin_display_bg"
        android:layout_marginStart="12dp"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Stats Panel -->
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">
            <TextView android:id="@+id/tvEnergy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Energy: 100%" android:textColor="#00FF00" android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvThreatSkill" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Threat Skill: 0" android:textColor="#FF0000" android:textSize="12sp" android:layout_marginTop="4dp"/>
            <TextView android:id="@+id/tvThreatResilience" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Threat Resilience: 0" android:textColor="#FF6600" android:textSize="12sp" android:layout_marginTop="4dp"/>
            <TextView android:id="@+id/tvDamage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Damage: 0" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp" android:visibility="gone"/>
            <TextView android:id="@+id/tvCrewStats" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Skill: 0 | XP: 0" android:textColor="#00FFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
            <TextView android:id="@+id/tvCoins" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Health Bars -->
    <ProgressBar
        android:id="@+id/soldierHealthBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="120dp"
        android:layout_height="8dp"
        android:progress="100"
        android:progressTint="#00FF00"
        app:layout_constraintBottom_toTopOf="@id/imgSoldier"
        app:layout_constraintStart_toStartOf="@id/imgSoldier"
        app:layout_constraintEnd_toEndOf="@id/imgSoldier"
        android:layout_marginBottom="8dp"/>

    <ProgressBar
        android:id="@+id/enemyHealthBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="120dp"
        android:layout_height="8dp"
        android:progress="100"
        android:progressTint="#FF0000"
        app:layout_constraintBottom_toTopOf="@id/imgAlien"
        app:layout_constraintStart_toStartOf="@id/imgAlien"
        app:layout_constraintEnd_toEndOf="@id/imgAlien"
        android:layout_marginBottom="8dp"/>

    <!-- Soldier -->
    <ImageView
        android:id="@+id/imgSoldier"
        android:layout_width="160dp"
        android:layout_height="280dp"
        android:src="@drawable/soldier"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="160dp"
        android:layout_marginStart="20dp"
        android:contentDescription="soldier"/>

    <!-- Alien/Tyranide -->
    <ImageView
        android:id="@+id/imgAlien"
        android:layout_width="140dp"
        android:layout_height="240dp"
        android:src="@drawable/tyranide"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="180dp"
        android:layout_marginEnd="30dp"
        android:contentDescription="alien"/>

    <!-- Projectile -->
    <ImageView
        android:id="@+id/projectile"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:contentDescription="projectile"/>

    <!-- Combat Log -->
    <TextView
        android:id="@+id/tvCombatLog"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="#AA000000"
        android:padding="8dp"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:scrollbars="vertical"
        android:maxLines="4"
        app:layout_constraintBottom_toTopOf="@id/buttonPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Buttons -->
    <LinearLayout
        android:id="@+id/buttonPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <Button android:id="@+id/btnShoot" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="SHOOT" android:layout_margin="4dp" android:backgroundTint="#CC2D82"/>
        <Button android:id="@+id/btnDodge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="DODGE" android:layout_margin="4dp" android:backgroundTint="#CC2D82"/>
        <Button android:id="@+id/btnGrenade" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="GRENADE" android:layout_margin="4dp" android:backgroundTint="#CC2D82"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
