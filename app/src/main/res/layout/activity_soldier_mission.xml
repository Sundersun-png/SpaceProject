<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/engineerback">

    <!-- Cloud/Mist Overlay for atmospheric effect -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#22FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Back button -->
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:text="← Back"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="@drawable/coin_display_bg"
        android:layout_marginStart="12dp"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Top Right Stats Panel -->
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvEnergy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Energy: 100%"
                android:textColor="#00FF00"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvThreatSkill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Threat Skill: 50"
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvThreatResilience"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Threat Resilience: 80"
                android:textColor="#FF6600"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvDamage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Damage: 0"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvCrewStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skill: 0 | XP: 0"
                android:textColor="#00FFFF"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Soldier (Left) -->
    <ImageView
        android:id="@+id/imgSoldier"
        android:layout_width="160dp"
        android:layout_height="280dp"
        android:src="@drawable/soldier"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="160dp"
        android:layout_marginStart="20dp"/>

    <!-- Alien (Right) -->
    <ImageView
        android:id="@+id/imgAlien"
        android:layout_width="140dp"
        android:layout_height="240dp"
        android:src="@drawable/tyranide"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="180dp"
        android:layout_marginEnd="30dp"/>

    <!-- Action Buttons in a vertical list at bottom right -->
    <LinearLayout
        android:id="@+id/buttonPanel"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="end"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnTorpedo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Torpedo Strike"
            android:textSize="11sp"
            android:layout_marginBottom="4dp"
            android:backgroundTint="#8B0000"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnPowerBoost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Power Boost"
            android:textSize="11sp"
            android:layout_marginBottom="4dp"
            android:backgroundTint="#00008B"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnReduceSkill"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reduce Skill"
            android:textSize="11sp"
            android:backgroundTint="#006400"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
