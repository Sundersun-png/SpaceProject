<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- BACKGROUND IMAGE -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_space_home"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- NAV BUTTONS CLUSTER — floats in the open sky area -->

    <!-- ADD CREW MEMBER — green button pinned to bottom -->



    <LinearLayout
        android:id="@+id/layoutNavButtons"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_above="@+id/btnAddCrewMember"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="65dp"
        android:layout_marginEnd="66dp"
        android:layout_marginBottom="66dp"
        android:gravity="center"
        android:orientation="vertical">

        <!-- ROW 1: Quarter + Simulator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnQuarters"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#552D82"
                android:text="Quarter"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:ignore="ButtonStyle,HardcodedText" />

            <Button
                android:id="@+id/btnSimulator"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#552D82"
                android:text="Simulator"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:ignore="ButtonStyle,HardcodedText" />

        </LinearLayout>

        <!-- ROW 2: Mission Control (full width) -->

        <!-- ROW 3: Statistics + Hospital -->
        <Button
            android:id="@+id/btnMissionControl"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#552D82"
            android:text="Mission Control"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStatistics"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#552D82"
                android:text="Statistics"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:ignore="ButtonStyle,HardcodedText" />

            <Button
                android:id="@+id/btnHospital"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#552D82"
                android:text="Hospital"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                tools:ignore="ButtonStyle,HardcodedText" />

        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btnAddCrewMember"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="94dp"
        android:layout_marginEnd="96dp"
        android:layout_marginBottom="285dp"
        android:backgroundTint="#1DB954"
        android:text="Add Crew Member"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText" />

</RelativeLayout>