<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/hospital">

    <!-- Dark overlay to make text readable -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"/>

    <!-- Back button -->
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:text="← Back"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/coin_display_bg"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MEDIC LAB"
        android:textColor="#00BCD4"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="70dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/ivMedic"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/medic"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Medic skill: 1"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/ivMedic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="30"
        android:textColor="#FFEB3B"
        android:textSize="70sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnTrain"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:text="TRAIN (30s)"
        android:textSize="18sp"
        android:backgroundTint="#00BCD4"
        android:textColor="#FFFFFF"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnInstantTrain"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:text="INSTANT TRAIN (5 🪙)"
        android:textSize="14sp"
        android:backgroundTint="#FFD700"
        android:textColor="#000000"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnTrain"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/llUnlockables"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="30dp"
        android:layout_marginHorizontal="32dp"
        android:padding="16dp"
        android:background="#44000000"
        app:layout_constraintTop_toBottomOf="@id/btnInstantTrain"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvPillLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💊 Pill Power (Req Skill: 9)"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/btnUnlockPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UNLOCK"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvHealLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💖 Heal Feature (Req Skill: 12)"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/btnUnlockHeal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UNLOCK HEAL"
            android:backgroundTint="#E91E63"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
