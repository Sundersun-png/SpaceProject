<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="800dp">

        <ImageView
            android:id="@+id/imgBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/background"
            android:contentDescription="@null" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#B0000010" />

        <RelativeLayout
            android:id="@+id/layoutTopBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_alignParentTop="true"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="#88000020">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:src="@android:drawable/ic_media_previous"
                android:background="@android:color/transparent"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="CREW RECRUITMENT"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layoutMainCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/layoutTopBar"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <!-- Current Crew Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#CC0A0A1E"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▸  CURRENT CREW"
                    android:textColor="#00FFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvCurrentCrewList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No crew members yet."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#CC0A0A1E"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▸  CREW MEMBER NAME"
                    android:textColor="#9B72CF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etCrewName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Enter crew member name..."
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textPersonName"
                    android:background="#330D0D30"
                    android:backgroundTint="#9B72CF" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#CC0A0A1E"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▸  SELECT SPECIALIZATION"
                    android:textColor="#9B72CF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:id="@+id/cardPilot"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#BB2D82"
                        android:layout_marginEnd="6dp"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👨‍🚀" android:textSize="28sp" android:layout_marginBottom="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PILOT" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardMedic"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#331A3A5C"
                        android:layout_marginEnd="6dp"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚕" android:textSize="28sp" android:layout_marginBottom="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MEDIC" android:textColor="#AAAACC" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardScientist"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#331A3A5C"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔬" android:textSize="28sp" android:layout_marginBottom="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SCIENTIST" android:textColor="#AAAACC" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <LinearLayout
                        android:id="@+id/cardEngineer"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#331A3A5C"
                        android:layout_marginEnd="6dp"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚙" android:textSize="28sp" android:layout_marginBottom="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ENGINEER" android:textColor="#AAAACC" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardSoldier"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#331A3A5C"
                        android:layout_marginEnd="6dp"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛡" android:textSize="28sp" android:layout_marginBottom="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SOLDIER" android:textColor="#AAAACC" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#CC0A0A1E"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▸  STATS PREVIEW"
                    android:textColor="#9B72CF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:id="@+id/tvSelectedClass"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="— PILOT —"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2"
                    android:background="#66BB2D82"
                    android:layout_marginBottom="14dp" />

                <!-- SKILL -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="34dp" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:text="⚔  SKILL" android:textColor="#AAAACC" android:textSize="13sp" />
                    <TextView android:id="@+id/tvSkillValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_alignParentEnd="true" android:text="5" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                </RelativeLayout>

                <!-- RESILIENCE -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="34dp" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:text="🛡  RESILIENCE" android:textColor="#AAAACC" android:textSize="13sp" />
                    <TextView android:id="@+id/tvResilienceValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_alignParentEnd="true" android:text="8" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                </RelativeLayout>

                <!-- MAX ENERGY -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="34dp" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:text="⚡  MAX ENERGY" android:textColor="#AAAACC" android:textSize="13sp" />
                    <TextView android:id="@+id/tvEnergyValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_alignParentEnd="true" android:text="100" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                </RelativeLayout>

                <!-- ABILITY -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="34dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:text="✨  ABILITY" android:textColor="#AAAACC" android:textSize="13sp" />
                    <TextView android:id="@+id/tvAbilityValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_alignParentEnd="true" android:text="Evade" android:textColor="#FFD700" android:textSize="14sp" android:textStyle="bold" />
                </RelativeLayout>

            </LinearLayout>

            <Button
                android:id="@+id/btnConfirmRecruit"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="⬡  RECRUIT CREW MEMBER"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.1"
                android:backgroundTint="#CC2D82"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </RelativeLayout>
</ScrollView>
