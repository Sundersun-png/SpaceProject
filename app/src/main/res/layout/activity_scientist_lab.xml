<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/missioncontrol"
        android:scaleType="centerCrop"
        android:alpha="0.2"
        android:contentDescription="@null"/>

    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:text="← Back"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="@drawable/coin_display_bg"
        android:layout_marginStart="12dp"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:id="@+id/coinDisplay"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/coin_display_bg"
        android:paddingStart="10dp"
        android:paddingEnd="14dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <View android:layout_width="18dp" android:layout_height="18dp" android:background="@drawable/coin_bg"/>
        <TextView android:id="@+id/tvCoins" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="25" android:textColor="#FFD700" android:textSize="14sp" android:textStyle="bold" android:layout_marginStart="6dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvScientistInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scientist: - | Skill: -"
        android:textColor="#AADDFF"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvScientistInfo"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Potion 1: Weakness Potion -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#CC1A1A2E">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧪 Weakness Potion" android:textColor="#FFFFFF" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Effect: Reduces UFO energy and speed" android:textColor="#AAAAAA" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvWeaknessStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Owned: 0" android:textColor="#90EE90" android:textSize="11sp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                        <Button android:id="@+id/btnPurchaseWeakness" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Purchase (5🪙)" android:textSize="10sp"/>
                        <Button android:id="@+id/btnAddWeakness" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Add (Skill: 8)" android:textSize="10sp" android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Potion 2: Power Boost -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#CC1A1A2E">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ Power Boost" android:textColor="#FFFFFF" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Effect: Free power boost for Pilot" android:textColor="#AAAAAA" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvPowerBoostStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Not Added" android:textColor="#FF6666" android:textSize="11sp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                        <Button android:id="@+id/btnPurchasePower" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Purchase (5🪙)" android:textSize="10sp"/>
                        <Button android:id="@+id/btnAddPower" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Add (Skill: 5)" android:textSize="10sp" android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Potion 3: Earn +5 Coins -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#CC1A1A2E">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💰 Coin Potion" android:textColor="#FFFFFF" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Effect: Instantly adds 5 coins" android:textColor="#AAAAAA" android:textSize="11sp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                        <Button android:id="@+id/btnPurchaseCoins" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Purchase (5🪙)" android:textSize="10sp"/>
                        <Button android:id="@+id/btnAddCoins" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Add (Skill: 10)" android:textSize="10sp" android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Potion 4: Increase all crew skill by +2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#CC1A1A2E">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎓 Skill Potion" android:textColor="#FFFFFF" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Effect: All crew (except scientist) skill +2" android:textColor="#AAAAAA" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvSkillBoostStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Not Applied" android:textColor="#FF6666" android:textSize="11sp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                        <Button android:id="@+id/btnPurchaseSkill" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Purchase (5🪙)" android:textSize="10sp"/>
                        <Button android:id="@+id/btnAddSkill" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Add (Skill: 9)" android:textSize="10sp" android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
