<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- BACKGROUND: floating arena / simulator image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/simulator"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Dark overlay so text is readable -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000010" />

    <!-- ══ TOP BAR ══ -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#BB000020"
        android:layout_alignParentTop="true">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@android:color/transparent"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="SIMULATOR"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/tvCoins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="12dp"
            android:text="🪙 300"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- ══ CREW PORTRAIT — shown centered when a crew is selected ══ -->
    <ImageView
        android:id="@+id/imgSelectedCrew"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_below="@id/topBar"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="Selected crew portrait" />

    <!-- ══ SCROLL CONTENT ══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Spacer pushes crew cards below portrait (portrait is 130dp + 12dp margin) -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="158dp" />

            <!-- Section label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▸ SELECT CREW MEMBER TO TRAIN"
                android:textColor="#9B72CF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp" />

            <!-- ── CREW A CARD ── -->
            <LinearLayout
                android:id="@+id/cardCrewA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#DD0A0A1E"
                android:padding="14dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical">

                <View
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="#BB2D82"
                    android:layout_marginEnd="14dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCrewAName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvCrewARole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Role"
                        android:textColor="#9B72CF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvCrewAStats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="XP: 0  |  Skill: —"
                        android:textColor="#AAAACC"
                        android:textSize="11sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvCrewAStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏳ Needs Training"
                    android:textColor="#FFD700"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- ── CREW B CARD ── -->
            <LinearLayout
                android:id="@+id/cardCrewB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#DD0A0A1E"
                android:padding="14dp"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical">

                <View
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="#2D82CC"
                    android:layout_marginEnd="14dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCrewBName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvCrewBRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Role"
                        android:textColor="#9B72CF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvCrewBStats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="XP: 0  |  Skill: —"
                        android:textColor="#AAAACC"
                        android:textSize="11sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvCrewBStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏳ Needs Training"
                    android:textColor="#FFD700"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- ══ TRAINING PANEL (hidden until crew selected) ══ -->
            <LinearLayout
                android:id="@+id/layoutTrainingPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#DD0A0A1E"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvTrainingName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Training: —"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <!-- Progress bar + 30s countdown side by side -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ProgressBar
                        android:id="@+id/progressTraining"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="20dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        android:progress="0"
                        android:max="100"
                        android:progressTint="#CC2D82"
                        android:progressBackgroundTint="#33FFFFFF" />

                    <TextView
                        android:id="@+id/tvCountdown"
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="30s"
                        android:textColor="#FFD700"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnStartTraining"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="▶  Start Training"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#552D82" />

                    <Button
                        android:id="@+id/btnInstantTrain"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="⚡ Instant (🪙 30)"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2D82CC" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>