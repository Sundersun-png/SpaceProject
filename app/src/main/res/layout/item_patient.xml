<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC1A1A2E">

    <!-- Top row: name + circles + countdown -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Patient name -->
        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Patient"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <!-- Critical circle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="14dp">

            <View
                android:id="@+id/circleCritical"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/circle_empty"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Critical"
                android:textColor="#AAAAAA"
                android:textSize="9sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Recovering circle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="14dp">

            <View
                android:id="@+id/circleRecovering"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/circle_empty"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recovering"
                android:textColor="#AAAAAA"
                android:textSize="9sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Healed circle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="14dp">

            <View
                android:id="@+id/circleHealed"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/circle_empty"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Healed"
                android:textColor="#AAAAAA"
                android:textSize="9sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Countdown -->
        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="60s"
            android:textColor="#AADDFF"
            android:textSize="12sp"
            android:gravity="end"/>

    </LinearLayout>

    <!-- Send to Mission Control button — only visible when healed -->
    <Button
        android:id="@+id/btnSendToMission"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="🚀  Send to Mission Control"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1A6B3C"
        android:visibility="gone"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="12dp"/>

</LinearLayout>
