<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/hospital">

    <!-- High-tech dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"/>

    <!-- Professional Header -->
    <View
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#CC004D40"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="← BACK"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:background="@drawable/coin_display_bg"
        android:layout_marginStart="16dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="@id/header"
        app:layout_constraintBottom_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Coin display in top right -->
    <LinearLayout
        android:id="@+id/coinDisplay"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/coin_display_bg"
        android:paddingStart="10dp"
        android:paddingEnd="14dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@id/header"
        app:layout_constraintBottom_toBottomOf="@id/header"
        app:layout_constraintEnd_toEndOf="parent">
        <View android:layout_width="18dp" android:layout_height="18dp" android:background="@drawable/coin_bg"/>
        <TextView android:id="@+id/tvCoins" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="0" android:textColor="#FFD700" android:textSize="14sp" android:textStyle="bold" android:layout_marginStart="6dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MEDIC LAB"
        android:textColor="#B2EBF2"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toTopOf="@id/header"
        app:layout_constraintBottom_toBottomOf="@id/header"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintEnd_toStartOf="@id/coinDisplay" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">

            <!-- Character Profile Section -->
            <FrameLayout
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:layout_marginTop="10dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/training_circle"
                    android:alpha="0.7"/>

                <ImageView
                    android:id="@+id/ivMedic"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_gravity="center"
                    android:src="@drawable/medic"
                    android:scaleType="centerInside"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medic skill: 1"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <!-- Training Hub -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#66000000"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvCountdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30"
                        android:textColor="#FFEB3B"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:visibility="gone"/>

                    <Button
                        android:id="@+id/btnTrain"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="INTENSIVE MEDICAL TRAINING"
                        android:backgroundTint="#00838F"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>

                    <Button
                        android:id="@+id/btnInstantTrain"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="FAST TRACK (5 🪙)"
                        android:backgroundTint="#FFA000"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tech Tree / Research -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LAB RESEARCH"
                android:textColor="#4DD0E1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:alpha="0.8"/>

            <!-- Pill Power Row -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#3300E676">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:id="@+id/tvPillLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💊 Pill Power" android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvPillDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Unlocks massive damage in Joint Missions. (Req XP: 9)" android:textColor="#CCCCCC" android:textSize="12sp"/>
                    <LinearLayout android:id="@+id/layoutPillButtons" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                        <Button android:id="@+id/btnBuyPill" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="BUY (5 🪙)" android:textSize="10sp" android:backgroundTint="#2E7D32" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btnUnlockPill" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="UNLOCK (XP: 9)" android:textSize="10sp" android:backgroundTint="#2E7D32" android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Heal Row -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#33F50057">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:id="@+id/tvHealLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💖 Heal Feature" android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvHealDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Instant recovery for all hospital patients. (Req XP: 12)" android:textColor="#CCCCCC" android:textSize="12sp"/>
                    <LinearLayout android:id="@+id/layoutHealButtons" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                        <Button android:id="@+id/btnBuyHeal" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="BUY (5 🪙)" android:textSize="10sp" android:backgroundTint="#AD1457" android:layout_marginEnd="4dp"/>
                        <Button android:id="@+id/btnUnlockHeal" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="UNLOCK (XP: 12)" android:textSize="10sp" android:backgroundTint="#AD1457" android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
