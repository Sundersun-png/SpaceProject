<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sky gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#B8E0F0"
                android:centerColor="#7EC8E3"
                android:endColor="#4A9FB5"
                android:angle="270"/>
        </shape>
    </item>
    <!-- Misty ground/mountains bottom -->
    <item android:top="500dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#AA7EC8E3"
                android:endColor="#CC4A9FB5"
                android:angle="270"/>
        </shape>
    </item>
    <!-- Platform dark base -->
    <item android:top="420dp" android:bottom="300dp" android:left="40dp" android:right="40dp">
        <shape android:shape="rectangle">
            <solid android:color="#553D2B1A"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <!-- Cloud left -->
    <item android:top="150dp" android:bottom="560dp" android:right="200dp">
        <shape android:shape="oval">
            <solid android:color="#AAFFFFFF"/>
        </shape>
    </item>
    <!-- Cloud right -->
    <item android:top="180dp" android:bottom="540dp" android:left="200dp">
        <shape android:shape="oval">
            <solid android:color="#88FFFFFF"/>
        </shape>
    </item>
</layer-list>