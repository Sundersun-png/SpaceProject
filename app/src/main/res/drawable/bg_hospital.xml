<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#E8F4F8"
                android:centerColor="#D0E8F0"
                android:endColor="#B8D8E8"
                android:angle="270"/>
        </shape>
    </item>
    <!-- Corridor wall lines -->
    <item android:left="0dp" android:right="350dp" android:top="100dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#22000000"/>
        </shape>
    </item>
</layer-list>